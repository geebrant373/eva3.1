		case "auto_buff_91": //카운터 배리어</a>:<var img src="#6": //<br>

		case "auto_buff_21": //블래스드 아머</a>:<var img src="#5": //<br>
		case "auto_buff_26": //인챈트 덱스터리티</a>:<var img src="#6": //<br>
		case "auto_buff_42": //인챈트 마이티</a>:<var img src="#7": //<br>
