			default:
			}
		}

		/** 일반악세 오림 목걸이 */
		if (itemtype == 8 && itemgrade != 3) {
			switch (enchantlevel) {
			case 1:
				_owner.addMaxHp(-5);
				break;
			case 2:
				_owner.addMaxHp(-10);
				break;
			case 3:
				_owner.addMaxHp(-20);
