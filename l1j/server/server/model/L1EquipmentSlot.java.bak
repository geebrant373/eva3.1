				}
				break;
			}
		}

		/** 일반악세 오림 반지 */
		if ((itemtype == 9 || itemtype == 11) && itemgrade != 3) {
			switch (enchantlevel) {
			case 1:
				_owner.addMaxHp(-5);
				break;
			case 2:
				_owner.addMaxHp(-10);
				break;
			case 3:
				_owner.addMaxHp(-20);
				break;
			case 4:
