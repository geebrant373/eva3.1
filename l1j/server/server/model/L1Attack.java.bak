		case 412000:
			dmg += WeaponSkill.getEffectSwordDamage(_pc, _target, 10);
			break;
		case 412001:
			calcDrainOfHp(dmg);
			break;
		case 412004:
			dmg += WeaponSkill.getIceSpearDamage(_pc, _target);
			break;
		case 412005:
