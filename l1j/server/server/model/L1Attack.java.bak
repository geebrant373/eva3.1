	private static final int[] strDmg = new int[128];

	static {
		// STR ЕЅЙЬСі КИСЄ
		for (int str = 0; str <= 8; str++) {
			// 1~8ДТ -2
			strDmg[str] = -2;
		}
		for (int str = 9; str <= 10; str++) {
			// 9~10ДТ -1
			strDmg[str] = -1;
		}
		strDmg[11] = 0;
		strDmg[12] = 0;
		strDmg[13] = 1;
		strDmg[14] = 1;
		strDmg[15] = 2;
		strDmg[16] = 2;
		strDmg[17] = 3;
		strDmg[18] = 3;
		strDmg[19] = 4;
		strDmg[20] = 4;
		strDmg[21] = 5;
		strDmg[22] = 5;
		strDmg[23] = 6;
		strDmg[24] = 6;
		strDmg[25] = 6;
		strDmg[26] = 7;
		strDmg[27] = 7;
		strDmg[28] = 7;
		strDmg[29] = 8;
		strDmg[30] = 8;
		strDmg[31] = 9;
		strDmg[32] = 9;
		strDmg[33] = 10;
		strDmg[34] = 11;
		int dmg = 12;
		for (int str = 35; str <= 127; str++) { // 35~127РК 4ИЖДйЃЋ1
			if (str % 4 == 1) {
				dmg++;
			}
			strDmg[str] = dmg;
		}
	}

	private static final int[] dexDmg = new int[128];

	static {
		// DEX ЕЅЙЬСі КИСЄ
		for (int dex = 0; dex <= 14; dex++) {
			// 0~14ДТ 0
			dexDmg[dex] = 0;
		}
		dexDmg[15] = 1;
		dexDmg[16] = 2;
		dexDmg[17] = 3;
		dexDmg[18] = 4;
		dexDmg[19] = 4;
		dexDmg[20] = 4;
		dexDmg[21] = 5;
		dexDmg[22] = 5;
		dexDmg[23] = 5;
		dexDmg[24] = 6;
		dexDmg[25] = 6;
		dexDmg[26] = 6;
		dexDmg[27] = 7;
		dexDmg[28] = 7;
		dexDmg[29] = 7;
		dexDmg[30] = 8;
		dexDmg[31] = 8;
		dexDmg[32] = 8;
		dexDmg[33] = 9;
		dexDmg[34] = 9;
		dexDmg[35] = 9;
		int dmg = 10;
		for (int dex = 36; dex <= 127; dex++) { // 36~127РК 4ИЖДйЃЋ1 //#
			if (dex % 4 == 1) {
				dmg++;
			}

			dexDmg[dex] = dmg;
		}
	}

