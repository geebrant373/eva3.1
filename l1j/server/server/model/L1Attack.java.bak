		case 383:
			dmg += 5;
			break;
		}
		L1ItemInstance ЙпЖѓФЋНКРЧПЯЗТ = _pc.getInventory().checkEquippedItem(420112);
		L1ItemInstance ЙпЖѓФЋНКРЧПЙСіЗТ = _pc.getInventory().checkEquippedItem(420113);
		L1ItemInstance ЙпЖѓФЋНКРЧРЮГЛЗТ = _pc.getInventory().checkEquippedItem(420114);
		L1ItemInstance ЙпЖѓФЋНКРЧИЖЗТ = _pc.getInventory().checkEquippedItem(420115);

		if (ЙпЖѓФЋНКРЧПЯЗТ != null) {
			int ЙпЕПТљНК = _random.nextInt(100);
			if (ЙпЕПТљНК <= 10) {
				if (_weaponType != 20 && _weaponType != 62) {
					dmg = +300;
					_ЙпЖѓБйАХИЎАЁШЃ = true;
				}
			}
		}
		if (ЙпЖѓФЋНКРЧПЙСіЗТ != null) {
			int ЙпЕПТљНК = _random.nextInt(100);
			if (ЙпЕПТљНК <= 10) {
				if (_weaponType != 20 && _weaponType != 62) {
					dmg = +200;
					_ЙпЖѓБйАХИЎАЁШЃ = true;
				}
			}
		}
		if (ЙпЖѓФЋНКРЧРЮГЛЗТ != null) {
			int ЙпЕПТљНК = _random.nextInt(100);
			if (ЙпЕПТљНК <= 10) {
				if (_weaponType == 20 || _weaponType == 62) {
					dmg = +200;
					_ЙпЖѓПјАХИЎАЁШЃ = true;
				}
			}
		}
		if (ЙпЖѓФЋНКРЧИЖЗТ != null) {
			int ЙпЕПТљНК = _random.nextInt(100);
			if (ЙпЕПТљНК <= 10) {
