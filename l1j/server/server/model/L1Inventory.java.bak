	public L1ItemInstance findItemTicketId(int id, int secid, int ticketid) {
		for (L1ItemInstance item : _items) {
			if (item.getItem().getItemId() == id && item.getSecondId() == secid && item.getTicketId() == ticketid) {
				return item;
			}
		}
		return null;
	}

	public L1ItemInstance findItemIdBless(int id, int bless) {
		for (L1ItemInstance item : _items) {
			if (item.getItem().getItemId() == id && item.getBless() == bless) {
				return item;
			}
		}
		return null;
	}

	public L1ItemInstance[] findItemsIdNotEquippedCraftBless(int id, int enchant, int bless) {
		ArrayList<L1ItemInstance> itemList = new ArrayList<L1ItemInstance>();
		for (L1ItemInstance item : _items) {
			if (item == null)
				continue;
			if (item.getItemId() == id) {
				if (!item.isEquipped() && item.getEnchantLevel() == enchant && item.getBless() == bless) {
					itemList.add(item);
				}
			}
		}
		return itemList.toArray(new L1ItemInstance[] {});
	}
	
	public int checkItemCount(int id) {
		int cnt = 0;
		L1ItemInstance item = null;
		for (Object itemObject : _items) {
			item = (L1ItemInstance) itemObject;
			if (item.getItemId() == id)
				cnt += item.getCount();
		}
		return cnt;
	}
