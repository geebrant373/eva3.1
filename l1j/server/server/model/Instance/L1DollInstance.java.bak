			master.sendPackets(new S_SystemMessage("마법인형 효과:오토루팅,AC-3,마법 적중+8,SP+15,기술 적중+15,스턴 내성+15,PvP대미지+4,PvP대미지 감소+2,MP절대 회복+40(15초),경험치보너스+40%,이펙트:헬파이어"));
