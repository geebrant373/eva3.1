		case DOLLTYPE_road:
			master.getAC().addAc(-1);
			master.addBowDmgup(2);
			master.addDamageReductionByArmor(2);
			master.sendPackets(new S_SystemMessage("마법인형 효과:AC-1,리덕션+2,원거리 대미지+2,엠피회복+20,경험치 보너스+20%,마법 발동:썬버스트"));
			break;

		case DOLLTYPE_데몬:
			master.getAC().addAc(-2);
			master.getResistance().addStun(10);
