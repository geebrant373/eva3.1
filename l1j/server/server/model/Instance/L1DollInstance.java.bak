			master.addPVPDamageReduction(2);
			master.sendPackets(new S_SPMR(master));
			master.sendPackets(new S_SystemMessage("마법인형 효과:오토루팅,AC-3,원거리 대미지+14,원거리 명중+8,기술 적중+15,정령 적중+15,스턴 내성+15,정령 내성+15,PvP대미지+4,PvP대미지 감소+2,MP절대회복+40(15초),경험치보너스+40%,이펙트:헬파이어"));
			break;

		case DOLLTYPE_발라카스:
			master.getAC().addAc(-3);
			master.addDmgup(6);
			master.addHitup(8);
			master.addHitup_skill(15);//3
			master.addHitup_spirit(15);//3
			master.getResistance().addStun(15);//8
			master.addHitupByDoll(15);//3
			master.addPVPDamage(4);
			master.addPVPDamageReduction(2);
			master.sendPackets(new S_SPMR(master));
			master.sendPackets(new S_SystemMessage("마법인형 효과:오토루팅,AC-3,근거리 대미지+6,근거리 명중+8,기술 적중+15,정령 적중+15,스턴 내성+15,정령 내성+15,PvP대미지+4,PvP대미지 감소+2,MP절대회복+40(15초),경험치보너스+40%,이펙트:헬파이어"));
			break;
	}

		startHelpTimer();
	}

	public void deleteDoll() {
		L1PcInstance pc = (L1PcInstance) _master;
		L1ItemInstance item = pc.getInventory().findItemObjId(_itemObjId);

		if (isMpRegeneration()) {
			((L1PcInstance) _master).stopMpRegenerationByDoll();
		} else if (isHpRegeneration()) {
			((L1PcInstance) _master).stopHpRegenerationByDoll();
		}

		int type = getDollType();
		switch (type) {
		case DOLLTYPE_BUGBEAR:
			_master.addHitup(-1);
			_master.addBowHitup(-1);
			break;

		case DOLLTYPE_WAREWOLF:
			_master.addMaxHp(-20);
			break;

		case DOLLTYPE_허수아비:
			_master.addMaxMp(-10);
			break;

		case DOLLTYPE_CRUSTACEA:
			_master.addBowDmgup(-1);
			break;

		case DOLLTYPE_SEADANCER:
			_master.getAbility().addSp(-1);
			_master.sendPackets(new S_SPMR(_master));
			break;

		case DOLLTYPE_에티:
			_master.getAC().addAc(2);
			break;

		case DOLLTYPE_라미아:
			_master.addDmgup(1);
			break;

		case DOLLTYPE_사이클롭스:
			_master.getAC().addAc(1);
			break;

		case DOLLTYPE_시어:
			_master.getAC().addAc(1);
			_master.addDmgup(-3);
			break;

		case DOLLTYPE_나이트발드:
			_master.getAC().addAc(1);
			_master.addBowDmgup(-3);
			break;

		case DOLLTYPE_리치:
			_master.getAC().addAc(1);
			_master.getAbility().addSp(-3);
			_master.sendPackets(new S_SPMR(_master));
			break;

		case DOLLTYPE_SUCCUBUS:
			_master.addDmgup(-1);
			_master.addBowDmgupByDoll(-1);
			_master.getAbility().addSp(-1);
			_master.sendPackets(new S_SPMR(_master));
			break;

		case DOLLTYPE_COCATRIS:
			_master.addBowDmgupByDoll(-1);
			break;

		case DOLLTYPE_스파토이:
			_master.addDmgup(-1);
			_master.addBowDmgup(-1);
			_master.getAbility().addSp(-1);
			_master.sendPackets(new S_SPMR(_master));
			break;

		case DOLLTYPE_ELDER:
			_master.getAbility().addSp(-1);
			_master.sendPackets(new S_SPMR(_master));
			break;

		case DOLLTYPE_road:
			_master.getAC().addAc(1);
			_master.addBowDmgup(-2);
			_master.addDamageReductionByArmor(-2);
			break;

		case DOLLTYPE_데몬:
			_master.getAC().addAc(2);
			_master.getResistance().addStun(-10);
			_master.addHitup_skill(-5);
			_master.addMaxHp(-200);
			break;

		case DOLLTYPE_데스나이트:
			_master.getAC().addAc(2);
			_master.sendPackets(new S_SPMR(_master));
			break;

		case DOLLTYPE_얼음여왕:
			_master.getAC().addAc(2);
			_master.addBowDmgup(-5);
			break;

		case DOLLTYPE_타락:
			_master.getAC().addAc(2);
			_master.getAbility().addSp(-5);
			_master.sendPackets(new S_SPMR(_master));
			break;

		case DOLLTYPE_바란카:
			_master.getAC().addAc(2);
			_master.addDmgup(-5);
			break;

		case DOLLTYPE_안타라스:
			_master.getAC().addAc(3);
			_master.addDamageReductionByArmor(-8);
			_master.addHitup_skill(-15);
			_master.getResistance().addStun(-15);
			_master.addPVPDamage(-6);
			_master.addPVPDamageReduction(-10);
			_master.sendPackets(new S_SPMR(_master));
			break;

		case DOLLTYPE_파푸리온:
			_master.getAC().addAc(3);
			_master.addHitup_magic(-8);
			_master.getAbility().addSp(-15);
			_master.addHitup_skill(-15);
			_master.getResistance().addStun(-15);
			_master.addPVPDamage(-4);
			_master.addPVPDamageReduction(-2);
			_master.sendPackets(new S_SPMR(_master));
			break;

		case DOLLTYPE_린드비오르:
			_master.getAC().addAc(3);
			_master.addBowDmgupByDoll(-14);
			_master.addBowHitup(-8);
			_master.addBowHitupByDoll(-15);
			_master.addHitup_skill(-15);
			_master.addHitup_spirit(-15);
			_master.getResistance().addStun(-15);
			_master.addPVPDamage(-4);
			_master.addPVPDamageReduction(-2);
			_master.sendPackets(new S_SPMR(_master));
			break;

		case DOLLTYPE_발라카스:
			_master.getAC().addAc(3);
			_master.addDmgup(-6);
			_master.addHitup(-8);
			_master.addHitup_skill(-15);
			_master.addHitup_spirit(-15);
			_master.getResistance().addStun(-15);
			_master.addHitupByDoll(-15);
			_master.addPVPDamage(-4);
			_master.addPVPDamageReduction(-2);
			_master.sendPackets(new S_SPMR(_master));
			break;
	}

		stopHelpTimer();
		_master.sendPackets(new S_SkillSound(getId(), 5936));
		Broadcaster.broadcastPacket(_master, new S_SkillSound(getId(), 5936));
		_master.getDollList().remove(getId());
		_master.setMagicDoll(null);
		deleteMe();
	}

	@Override
	public void onPerceive(L1PcInstance perceivedFrom) {
		perceivedFrom.getNearObjects().addKnownObject(this);
		perceivedFrom.sendPackets(new S_DollPack(this, perceivedFrom));
	}
	
	@Override
	public void onItemUse() {
		if (!isActived()) {
			// 100%의 확률로 헤이 파업 일부 사용
			useItem(USEITEM_HASTE, 100);
		}
	}

	@Override
	public void onGetItem(L1ItemInstance item) {
		if (getNpcTemplate().get_digestitem() > 0) {
			setDigestItem(item);
		}
		if (Arrays.binarySearch(haestPotions, item.getItem().getItemId()) >= 0) {
			useItem(USEITEM_HASTE, 100);
		}
	}

