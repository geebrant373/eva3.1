			master.sendPackets(new S_SystemMessage("마법인형 효과: AC-2,엠피회복+20,경험치 보너스+30%,HP+200,스턴적중+5,스턴내성+10,마법 발동:헬파이어"));
			break;

		case DOLLTYPE_데스나이트:
			master.getAC().addAc(-2);
			master.sendPackets(new S_SPMR(master));
			master.sendPackets(new S_SystemMessage("마법인형 효과: AC-2,엠피회복+20,경험치 보너스+30%,리덕션+5,마법 발동:헬파이어"));
			break;

		case DOLLTYPE_얼음여왕:
			master.getAC().addAc(-2);
			master.addBowDmgup(5);
			master.sendPackets(new S_SystemMessage("마법인형 효과: AC-2,엠피회복+20,경험치 보너스+30%,원거리대미지+5,마법 발동:헬파이어"));
			break;

		case DOLLTYPE_타락:
			master.getAC().addAc(-2);
			master.getAbility().addSp(5);
			master.sendPackets(new S_SPMR(master));
			master.sendPackets(new S_SystemMessage("마법인형 효과:AC-2,엠피회복+20,경험치 보너스+30%,SP+5,마법 발동:헬파이어"));
			break;

		case DOLLTYPE_바란카:
			master.getAC().addAc(-2);
			master.addDmgup(5);
			master.sendPackets(new S_SystemMessage("마법인형 효과:AC-2,엠피회복+20,경험치 보너스+30%,근거리대미지+5%,마법 발동:헬파이어"));
			break;

		case DOLLTYPE_안타라스:
			master.getAC().addAc(-3);
			master.addDamageReductionByArmor(8);//6
			master.addHitup_skill(15);//3
			master.getResistance().addStun(15);//8
			master.addPVPDamage(6);
			master.addPVPDamageReduction(10);//2
			master.sendPackets(new S_SPMR(master));
			master.sendPackets(new S_SystemMessage("마법인형 효과:오토루팅,AC-3,대미지 리덕션+8,기술 적중+15,스턴 내성+15,PvP대미지+6,PvP대미지 감소+10,MP절대회복+40(15초),경험치 보너스+40%,이펙트:헬파이어"));
