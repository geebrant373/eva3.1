		case DOLLTYPE_SUCCUBUS:
			master.addDmgup(1);
			master.addBowDmgupByDoll(1);
			master.getAbility().addSp(1);
			master.sendPackets(new S_SPMR(master));
			master.sendPackets(new S_SystemMessage("마법인형 효과: 근거리추타+1,원거리추타+1,SP+1,엠피회복+5,경험치 보너스+5%"));
