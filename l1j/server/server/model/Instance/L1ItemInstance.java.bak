			// 축복 수치
			if (get_bless_level() != 0) {
				if (getItem().getItemId() == 9 || getItem().getItemId() == 190 || getItem().getItemId() == 317 || getItem().getItemId() == 127 ||
					getItem().getItemId() == 54 || getItem().getItemId() == 164 || getItem().getItemId() == 205 || getItem().getItemId() == 124 || 
