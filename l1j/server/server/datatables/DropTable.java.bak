			// 40135))// 토템
			//
			// && totalHate > 0) { // 오토 루팅이나 아데나로 취득자가 있는 경우
			
			boolean dollauto = false;
			if (itemId == 40308 ||itemId == 41159 ||itemId == 430023 ||itemId == 40969 ||itemId == 8217
					 ||itemId == 45094||itemId == 46094||itemId == 47094
