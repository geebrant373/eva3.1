					||itemId == 500025||itemId == 500026||itemId == 500027||itemId == 500028||itemId == 3000011 //220521 기운고대검방/멸/안타상자추가겜블
							){ // 여길 제하면 모든템이 오토루팅
				for (L1DollInstance doll : pc.getDollList().values()) {
